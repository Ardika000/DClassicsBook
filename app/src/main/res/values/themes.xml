<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        Theme menggunakan palet Figma:
          Primary     = #5E4C3E (dark brown)
          Background  = #F5F5EB (ivory)
          Surface     = #F5F5EB
    -->
    <style name="Base.Theme.DClassicsBook" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brown_dark</item>
        <item name="colorOnPrimary">@color/bg_ivory</item>
        <item name="colorPrimaryContainer">@color/beige_warm</item>
        <item name="colorOnPrimaryContainer">@color/brown_dark</item>
        <item name="colorSecondary">@color/brown_accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/bg_ivory</item>
        <item name="colorOnSurface">@color/brown_dark</item>
        <item name="colorError">#C0392B</item>
        <item name="android:windowBackground">@color/bg_ivory</item>
        <item name="android:statusBarColor">@color/bg_ivory</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
        <item name="android:navigationBarColor">@color/bg_ivory</item>
    </style>

    <style name="Theme.DClassicsBook" parent="Base.Theme.DClassicsBook" />

    <!-- ── Reusable Component Styles ──────────────────────────────────────── -->
    <style name="FormLabelStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/brown_dark</item>
        <item name="android:textSize">14sp</item>
        <item name="fontFamily">@font/poppins</item>
    </style>

    <style name="FormInputStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:textColor">@color/brown_dark</item>
        <item name="android:textColorHint">#8A7765</item>
        <item name="android:textSize">13sp</item>
        <item name="fontFamily">@font/poppins</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:background">@drawable/bg_rounded_input</item>
    </style>

    <!-- ── Auth (Login / Register) reusable styles ────────────────────────── -->
    <style name="AuthLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/brown_dark</item>
        <item name="android:textSize">16sp</item>
        <item name="fontFamily">@font/poppins</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <!-- Pill container that holds a leading icon + EditText (+ optional eye) -->
    <style name="AuthInputContainer">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:background">@drawable/bg_auth_input</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>

    <style name="AuthEditText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">12dp</item>
        <item name="android:background">@null</item>
        <item name="android:textColor">@color/brown_dark</item>
        <item name="android:textColorHint">@color/brown_accent</item>
        <item name="android:textSize">14sp</item>
        <item name="fontFamily">@font/poppins</item>
        <item name="android:maxLines">1</item>
    </style>

    <style name="AuthButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/bg_ivory</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">@font/poppins</item>
        <item name="android:background">@drawable/btn_auth</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <!-- ── Shared dialog look (logout confirmation, booking) ──────────────── -->
    <style name="ThemeOverlay.DClassicsBook.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/auth_card_bg</item>
        <item name="colorOnSurface">@color/brown_dark</item>
        <item name="colorPrimary">@color/brown_dark</item>
        <item name="alertDialogStyle">@style/MaterialAlertDialog.DClassicsBook</item>
        <item name="materialAlertDialogTitleTextStyle">@style/MaterialAlertDialog.DClassicsBook.Title</item>
        <item name="materialAlertDialogBodyTextStyle">@style/MaterialAlertDialog.DClassicsBook.Body</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.DClassicsBook.DialogButton.Positive</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.DClassicsBook.DialogButton</item>
    </style>

    <style name="MaterialAlertDialog.DClassicsBook" parent="MaterialAlertDialog.Material3">
        <item name="backgroundTint">@color/auth_card_bg</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.DClassicsBook.Dialog</item>
    </style>

    <style name="ShapeAppearance.DClassicsBook.Dialog" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <style name="MaterialAlertDialog.DClassicsBook.Title" parent="MaterialAlertDialog.Material3.Title.Text">
        <item name="android:textColor">@color/brown_dark</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">@font/poppins</item>
    </style>

    <style name="MaterialAlertDialog.DClassicsBook.Body" parent="MaterialAlertDialog.Material3.Body.Text">
        <item name="android:textColor">@color/brown_darkest</item>
        <item name="android:textSize">14sp</item>
        <item name="fontFamily">@font/poppins</item>
    </style>

    <style name="Widget.DClassicsBook.DialogButton" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/brown_dark</item>
        <item name="android:textSize">14sp</item>
        <item name="fontFamily">@font/poppins</item>
    </style>

    <style name="Widget.DClassicsBook.DialogButton.Positive">
        <item name="android:textStyle">bold</item>
    </style>

    <!-- ── Profile dropdown (anchored popup, no background dim) ───────────── -->
    <style name="Animation.DClassicsBook.Popup" parent="@android:style/Animation">
        <item name="android:windowEnterAnimation">@anim/tab_fade_in</item>
        <item name="android:windowExitAnimation">@anim/tab_fade_out</item>
    </style>

</resources>