<?xml version="1.0" encoding="utf-8"?>
<!-- A single full-width page in the "Our Stores" ViewPager2 carousel -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/imgStore"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_store_image"
        android:clipToOutline="true"
        android:contentDescription="@string/cd_store_image"
        tools:src="@drawable/bg_store_image" />

    <TextView
        android:id="@+id/tvStoreName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:textColor="@color/brown_dark"
        android:textSize="15sp"
        android:textStyle="bold"
        android:fontFamily="@font/poppins"
        android:maxLines="1"
        android:ellipsize="end"
        tools:text="Forest Serenity" />

</LinearLayout>
