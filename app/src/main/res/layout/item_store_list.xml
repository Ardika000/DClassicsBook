<?xml version="1.0" encoding="utf-8"?>
<!-- A single store row on the Stores page: photo + brand + branch name + address -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_book_card"
    android:padding="12dp"
    android:layout_marginBottom="16dp"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/imgStore"
        android:layout_width="100dp"
        android:layout_height="92dp"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_store_image"
        android:clipToOutline="true"
        android:contentDescription="@string/cd_store_image"
        tools:src="@drawable/bg_store_image" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/store_brand"
            android:textColor="@color/brown_dark"
            android:textSize="17sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins" />

        <TextView
            android:id="@+id/tvStoreName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/brown_accent"
            android:textSize="12sp"
            android:fontFamily="@font/poppins"
            tools:text="Forest Serenity" />

        <View
            android:layout_width="150dp"
            android:layout_height="1dp"
            android:layout_marginTop="7dp"
            android:layout_marginBottom="7dp"
            android:background="@color/brown_accent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="13dp"
                android:layout_height="13dp"
                android:src="@drawable/ic_pin"
                android:contentDescription="@string/cd_pin" />

            <TextView
                android:id="@+id/tvStoreAddress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:textColor="@color/brown_accent"
                android:textSize="10sp"
                android:fontFamily="@font/poppins"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Jl. Hutan Pinus No. 9, Kota Rembulan" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
