<?xml version="1.0" encoding="utf-8"?>
<!--
    Books page (spec module 4): search bar, "All-Time Favourite" row, a
    Fiction / Non-Fiction tab control and a grid repeater, plus the reusable
    bottom navigation (Books active).
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootBooks"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_ivory"
    tools:context=".ui.main.BooksActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/booksContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingBottom="20dp">

            <!-- ── Top bar: search + cart ─────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_search_bar"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_search"
                        android:contentDescription="@string/cd_search" />

                    <EditText
                        android:id="@+id/etSearchBooks"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:background="@null"
                        android:hint="@string/home_search_hint"
                        android:textColorHint="@color/brown_accent"
                        android:textColor="@color/brown_dark"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins"
                        android:inputType="text"
                        android:imeOptions="actionSearch"
                        android:maxLines="1" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/btnCart"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginStart="16dp"
                    android:src="@drawable/ic_cart"
                    android:contentDescription="@string/cd_cart"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- ── "All-Time Favourite" header ────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginTop="26dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/books_favourite"
                    android:textColor="@color/brown_dark"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins" />

                <TextView
                    android:id="@+id/tvSeeAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/books_see_all"
                    android:textColor="@color/brown_accent"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins"
                    android:padding="4dp"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Favourite row -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFavourite"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:clipToPadding="false"
                android:scrollbars="none"
                tools:listitem="@layout/item_book_vert"
                tools:orientation="horizontal" />

            <!-- ── "Find Yours" + Tab Control ─────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/books_find_yours"
                android:textColor="@color/brown_dark"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginTop="26dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_segment_track"
                android:padding="5dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="14dp">

                <TextView
                    android:id="@+id/tabFiction"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/tab_fiction"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins"
                    android:background="@drawable/bg_segment_active"
                    android:textColor="@color/bg_ivory"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/tabNonFiction"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/tab_nonfiction"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins"
                    android:textColor="@color/brown_dark"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Grid repeater -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvBooksGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_book_vert" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Reusable bottom navigation (Books active) -->
    <com.example.dclassicsbook.ui.widget.BottomNavBar
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>
