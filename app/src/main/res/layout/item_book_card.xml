<?xml version="1.0" encoding="utf-8"?>
<!--
    A single row in the "Timeless Classic Books" list.
    The cover image overlaps the rounded info card on its left edge (raised
    with elevation) to match the Figma home design.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true">

    <!-- Rounded info card (sits behind the cover) -->
    <View
        android:id="@+id/bookCard"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:background="@drawable/bg_book_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
         />

    <!-- Book cover (overlaps card, rounded + raised shadow) -->
    <ImageView
        android:id="@+id/imgCardCover"
        android:layout_width="100dp"
        android:layout_height="149dp"
        android:layout_marginStart="12dp"
        android:background="@drawable/bg_book_cover_rounded"
        android:clipToOutline="true"
        android:contentDescription="@string/cd_book_cover"
        android:elevation="8dp"
        android:layout_marginBottom="45dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:src="@drawable/pride_and_prejudice" />

    <!-- Text block -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintStart_toEndOf="@id/imgCardCover"
        android:layout_marginStart="20dp"
        app:layout_constraintEnd_toEndOf="@id/bookCard"
        android:layout_marginEnd="18dp"
        app:layout_constraintTop_toTopOf="@id/bookCard"
        app:layout_constraintBottom_toBottomOf="@id/bookCard">

        <TextView
            android:id="@+id/tvCardTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/brown_dark"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins"
            android:lineSpacingMultiplier="1.05"
            android:maxLines="2"
            android:ellipsize="end"
            tools:text="Pride and Prejudice" />

        <TextView
            android:id="@+id/tvCardAuthor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/brown_accent"
            android:textSize="11sp"
            android:fontFamily="@font/poppins"
            tools:text="Jane Austen   |   1813" />

        <View
            android:layout_width="120dp"
            android:layout_height="1dp"
            android:background="@color/brown_accent" />

        <TextView
            android:id="@+id/tvCardGenres"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/brown_dark"
            android:textSize="10sp"
            android:fontFamily="@font/poppins"
            android:maxLines="1"
            android:layout_marginTop="5dp"
            android:ellipsize="end"
            tools:text="Romance, Drama, Social, Classic" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
