<?xml version="1.0" encoding="utf-8"?>
<!--
    Home page (Figma: UX_DClassicalBook).
    Everything above the bottom bar scrolls; the BottomNavBar stays pinned.
    Top / bottom system-bar insets are applied in MainActivity.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootHome"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_ivory"
    tools:context=".ui.main.MainActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/homeContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingBottom="20dp">

            <!-- ── HEADER: greeting + avatar ──────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_greeting"
                        android:textColor="@color/brown_dark"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins" />

                    <TextView
                        android:id="@+id/tvUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_user_name"
                        android:textColor="@color/brown_dark"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/imgAvatar"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:padding="12dp"
                    android:background="@drawable/bg_avatar"
                    android:src="@drawable/ic_profile"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/cd_avatar" />
            </LinearLayout>

            <!-- ── SEARCH BAR ─────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_search_bar"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="22dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_search"
                    android:contentDescription="@string/cd_search" />

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:background="@null"
                    android:hint="@string/home_search_hint"
                    android:textColorHint="@color/brown_accent"
                    android:textColor="@color/brown_dark"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:maxLines="1" />
            </LinearLayout>

            <!-- ── "Our Stores" header ────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginTop="28dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/home_section_stores"
                    android:textColor="@color/brown_dark"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins" />

                <TextView
                    android:id="@+id/tvViewAllStores"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_view_all"
                    android:textColor="@color/brown_accent"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins"
                    android:padding="4dp"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- ── Stores carousel (ViewPager2 + prev/next + dots) ────────── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/vpStores"
                    android:layout_width="match_parent"
                    android:layout_height="190dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:clipToPadding="false" />

                <ImageButton
                    android:id="@+id/btnStorePrev"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="24dp"
                    android:src="@drawable/ic_chevron_left"
                    android:background="@drawable/bg_carousel_btn"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/cd_prev" />

                <ImageButton
                    android:id="@+id/btnStoreNext"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="24dp"
                    android:src="@drawable/ic_chevron_right"
                    android:background="@drawable/bg_carousel_btn"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/cd_next" />
            </FrameLayout>

            <!-- Carousel page indicator -->
            <LinearLayout
                android:id="@+id/storeDots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:layout_marginTop="12dp" />

            <!-- ── "Timeless Classic Books" header ────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_section_books"
                android:textColor="@color/brown_dark"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginTop="28dp" />

            <!-- ── Books list ─────────────────────────────────────────────── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvBooks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_book_card" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── Reusable bottom navigation (pinned) ────────────────────────────── -->
    <com.example.dclassicsbook.ui.widget.BottomNavBar
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>
