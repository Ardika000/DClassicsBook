<?xml version="1.0" encoding="utf-8"?>
<!-- A single store thumbnail in the "Our Stores" horizontal carousel -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="152dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginEnd="14dp"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/imgStore"
        android:layout_width="match_parent"
        android:layout_height="104dp"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_store_image"
        android:contentDescription="@string/cd_store_image"
        tools:src="@drawable/bg_store_image" />

    <TextView
        android:id="@+id/tvStoreName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textColor="@color/brown_dark"
        android:textSize="13sp"
        android:fontFamily="@font/poppins"
        android:maxLines="1"
        android:ellipsize="end"
        tools:text="Forest Serenity" />

</LinearLayout>
