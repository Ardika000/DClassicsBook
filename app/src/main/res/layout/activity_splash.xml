<?xml version="1.0" encoding="utf-8"?>
<!--
    Splash / router. Layar singkat yang menentukan halaman pertama:
    Register, Login, atau Home (lihat SplashActivity).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res/auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/bg_ivory">

    <ImageView
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:src="@drawable/logo_dclassic" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/auth_tagline"
        android:textColor="@color/brown_dark"
        android:textSize="12sp"
        android:fontFamily="@font/poppins_bold" />

</LinearLayout>
